# Copy this file to `.env` and adjust as needed. `.env` is gitignored.
# docker-compose reads the POSTGRES_* values; the backend reads DATABASE_URL.

# --- PostgreSQL (local Docker dev) ---
POSTGRES_USER=agri
POSTGRES_PASSWORD=agri_dev_pw
POSTGRES_DB=agri
POSTGRES_PORT=5432

# SQLAlchemy URL the backend connects with.
# Local Docker dev (must match the POSTGRES_* values above):
DATABASE_URL=postgresql+psycopg://agri:agri_dev_pw@localhost:5432/agri
# In production (e.g. Render) set DATABASE_URL to the managed Postgres URL instead.

# --- External APIs (used in later CropAdvisor phases) ---
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api
# GEOCODING_API_KEY=        # only if a paid geocoder is added
# SATELLITE_API_KEY=        # only when NDVI/remote sensing is added
